{
  "name": "wms-platform",
  "private": true,
  "version": "1.0.0",
  "description": "WMS Platform - Inventory & Accounting Sync (QuickBooks Desktop + ShipRush)",
  "author": "Breezy Bay",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.xstaticpro.wms",
    "productName": "WMS Platform",
    "files": ["app/**/*", "electron/**/*"],
    "extraResources": [{ "from": "resources", "to": "resources" }],
    "directories": { "output": "release" },
    "win": { "target": "nsis", "icon": "resources/icon-512.png" },
    "mac": { "target": "dmg", "icon": "resources/icon-512.png", "category": "public.app-category.business" },
    "linux": { "target": "AppImage", "icon": "resources/icon-512.png", "category": "Office" }
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  }
}
