{
  "name": "wms-app",
  "private": true,
  "version": "0.0.0",
  "description": "Breezy Bay WMS - inventory, receiving and order management",
  "author": "Breezy Bay",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "icons": "node scripts/build-icons.mjs",
    "electron:dev": "concurrently -k -s first \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "net.breezybay.wms",
    "productName": "Breezy Bay WMS",
    "desktopName": "breezy-bay-wms.desktop",
    "files": ["dist/**/*", "electron/**/*"],
    "directories": { "output": "release" },
    "win": { "target": "nsis", "icon": "public/icon-512.png" },
    "mac": { "target": "dmg", "icon": "public/icon-512.png", "category": "public.app-category.business" },
    "linux": { "target": "AppImage", "icon": "public/icon-512.png", "category": "Office", "syncDesktopName": true }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "sharp": "^0.35.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^9.0.10"
  }
}
